{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "battu",
  "main": "worker/index.js",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": { "enabled": false }
}
